{
  "name": "orbayu",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": "^24",
    "pnpm": "^10"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "prepare": "husky",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "lint:ci": "pnpm run lint:check --cache --cache-strategy content --cache-location ~/.cache/eslint/orbayu",
    "build": "tsc --project tsconfig.build.json",
    "test": "vitest run",
    "coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@antfu/eslint-config": "7.7.3",
    "@vitest/coverage-v8": "4.1.2",
    "eslint": "10.1.0",
    "eslint-plugin-format": "2.0.1",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "typescript": "5.9.3",
    "vite": "8.0.3",
    "vitest": "4.1.2"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
